# NPM Configuration for Performance & Security

# Disable audit on install (can be slow in CI, use npm audit in separate step if needed)
audit=false

# Use exact versions (no floating ^)
save-exact=true

# Connection timeout
fetch-timeout=60000

# Retry failed requests
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Use legacy peer deps handling if needed (uncomment if required)
# legacy-peer-deps=true
